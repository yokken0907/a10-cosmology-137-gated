diff --git a/include/background.h b/include/background.h
index fe4d42d8..be89ec8a 100644
--- a/include/background.h
+++ b/include/background.h
@@ -78,6 +78,8 @@ struct background
   double Gamma_dcdm;      /**< \f$ \Gamma_{dcdm} \f$: decay constant for decaying cold dark matter */
   double tau_dcdm;
 
+  double ua10_current_Gamma; /* 現在のステップにおけるドラッグ強度 */
+
   int N_ncdm;                            /**< Number of distinguishable ncdm species */
   /* the following parameters help to define tabulated ncdm p-s-d passed in file */
   char * ncdm_psd_files;                 /**< list of filenames for tabulated p-s-d */
@@ -159,6 +161,26 @@ struct background
   int index_bg_H;             /**< Hubble parameter in \f$Mpc^{-1}\f$ */
   int index_bg_H_prime;       /**< its derivative w.r.t. conformal time */
 
+/* --- Unified A10 Project Parameters --- */
+  short has_unified_a10;           /* モデル起動スイッチ */
+  double ua10_phi_ini;             /* 初期値 */
+  double ua10_phi_trigger;         /* ゲートの中心（137.0） */
+  double ua10_Delta_phi;           /* ゲートの幅 */
+  double ua10_V0;                  /* ポテンシャル振幅 */
+  double ua10_f_ax;                /* スケール */
+  double ua10_n_ax;                /* べき数 */
+  double ua10_Gamma0;              /* ドラッグ強度 */
+
+  /* 背景積分のためのインデックス */
+  int index_bi_phi;                /* 積分変数phi */
+  int index_bi_phidot;             /* 積分変数phidot */
+
+  /* 派生出力のためのインデックス */
+  int index_bg_rho_phi;            /* 密度出力用 */
+  int index_bg_w_phi;              /* 状態方程式出力用 */
+  int index_bg_Gamma_drag;         /* ドラッグ強度出力用 */
+  /* -------------------------------------- */
+
   /* end of vector in short format, now quantities in normal format */
 
   int index_bg_rho_g;         /**< photon density */
@@ -192,6 +214,10 @@ struct background
 
   int index_bg_Omega_r;       /**< relativistic density fraction (\f$ \Omega_{\gamma} + \Omega_{\nu r} \f$) */
 
+/* A10 Project: RBH Indices */
+  int index_bg_rho_rbh;    /**< RBH density */
+  int index_bg_p_rbh;      /**< RBH pressure */
+
   /* end of vector in normal format, now quantities in long format */
 
   int index_bg_rho_crit;      /**< critical density */
@@ -292,6 +318,11 @@ struct background
   short has_curvature; /**< presence of global spatial curvature? */
   short has_varconst;  /**< presence of varying fundamental constants? */
 
+ /* A10 Project: Regular Black Hole Cosmological Coupling */
+  short has_rbh;          /**< presence of Regular Black Hole (RBH)? */
+  double Omega0_rbh;      /**< RBH density parameter today */
+  double rbh_coupling_k;  /**< RBH mass coupling strength to scale factor */
+
   //@}
 
 
