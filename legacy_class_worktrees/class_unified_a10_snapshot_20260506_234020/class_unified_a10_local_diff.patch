--- a/source/background.c
+++ b/source/background.c
@@ -442,6 +442,22 @@ int background_functions(
     rho_m += pvecback[pba->index_bg_rho_cdm];
   }
 
+/* A10 Project: RBH Cosmological Coupling */
+  if (pba->has_rbh == _TRUE_) {
+    /* 密度の計算: rho_rbh = Omega_rbh * H0^2 * a^(-3+k) */
+    pvecback[pba->index_bg_rho_rbh] = pba->Omega0_rbh * pow(pba->H0,2) * pow(a, -3.0 + pba->rbh_coupling_k);
+    
+    /* 圧力の計算: p_rbh = w_eff * rho = -(k/3) * rho_rbh */
+    pvecback[pba->index_bg_p_rbh] = -(pba->rbh_coupling_k / 3.0) * pvecback[pba->index_bg_rho_rbh];
+
+    /* 宇宙の総エネルギー密度と総圧力にRBHの寄与を加算 */
+    rho_tot += pvecback[pba->index_bg_rho_rbh];
+    p_tot += pvecback[pba->index_bg_p_rbh];
+    
+    /* RBHを物質成分(rho_m)としてもカウントする（初期宇宙での挙動のため） */
+    rho_m += pvecback[pba->index_bg_rho_rbh];
+  }
+
   /* idm */
   if (pba->has_idm == _TRUE_) {
     pvecback[pba->index_bg_rho_idm] = pba->Omega0_idm * pow(pba->H0,2) / pow(a,3);
@@ -572,6 +588,39 @@ int background_functions(
     rho_r += pvecback[pba->index_bg_rho_idr];
   }
 
+/* 1. 各成分の密度計算（既存のループ内） */
+    if (pba->has_unified_a10 == _TRUE_) {
+        /* 積分変数 y からではなく、ここでは受け渡された pvecback_B 等から取得 */
+        double phi = pvecback_B[pba->index_bi_phi];
+        double phi_prime = pvecback_B[pba->index_bi_phidot];
+
+        double f_ax = pba->ua10_f_ax;
+        double one_minus_cos = 1.0 - cos(phi / f_ax);
+        double V = pba->ua10_V0 * pow(one_minus_cos, pba->ua10_n_ax);
+
+        /* 密度の計算：運動エネルギー + ポテンシャルエネルギー */
+        double rho_phi = (0.5 * phi_prime * phi_prime / (a * a)) + V;
+        double p_phi   = (0.5 * phi_prime * phi_prime / (a * a)) - V;
+
+        /* 合計密度 rho_tot に A10 の寄与をしっかりと加算 */
+        rho_tot += rho_phi;
+        p_tot += p_phi;
+
+        /* 出力用データの保存 */
+        pvecback[pba->index_bg_rho_phi] = rho_phi;
+        /* ゼロ割りを防ぐ安全な状態方程式パラメータ w の計算 */
+        pvecback[pba->index_bg_w_phi] = (rho_phi != 0.0) ? (p_phi / rho_phi) : -1.0;
+    }
+
+/* 2. --- YOSHIMURA A-LINE V2-PRIME REBOOT --- (H の計算の直前！) */
+{
+    double a_star = 1. / (1. + 3000.);
+    double x_aline = a / a_star;
+    double f_star = 0.20;
+    /* rho_tot を最終的にブースト（rs_d を縮めるための最後のひと押し） */
+    rho_tot *= (1.0 + f_star * (pow(x_aline, 3.0) / (1.0 + pow(x_aline, 8.0))));
+}
+
   /** - compute expansion rate H from Friedmann equation: this is the
       only place where the Friedmann equation is assumed. Remember
       that densities are all expressed in units of \f$ [3c^2/8\pi G] \f$, ie
@@ -674,6 +723,32 @@ int background_w_fld(
   double d2Omega_ede_over_da2 = 0.;
   double a_eq, Omega_r, Omega_m;
 
+/** 変更ここから：CDM有効変形モデル（安定化版） **/
+  double Delta0 = pba->w0_fld; 
+  double n_idx = pba->wa_fld;      
+  double oma = 1.0 - a;        
+
+  if (oma < 1e-10) {
+    *integral_fld = 0.0;
+    *w_fld = 0.0;
+    *dw_over_da_fld = 0.0;
+  } else if (a < 1e-15) {
+    /* 初期宇宙(a=0)でのlog(0)によるNaN回避 */
+    *integral_fld = 1e10; /* 十分に大きな値 */
+    *w_fld = Delta0 / 3.0;
+    *dw_over_da_fld = -n_idx * Delta0 / 3.0;
+  } else {
+    double Delta = Delta0 * pow(oma, n_idx);
+    double dDelta_da = -n_idx * Delta0 * pow(oma, n_idx - 1.0);
+    double d2Delta_da2 = n_idx * (n_idx - 1.0) * Delta0 * pow(oma, n_idx - 2.0);
+
+    *integral_fld = (-3.0 - Delta) * log(a);
+    *w_fld = (1.0 / 3.0) * (Delta + a * log(a) * dDelta_da);
+    *dw_over_da_fld = (1.0 / 3.0) * ((2.0 + log(a)) * dDelta_da + a * log(a) * d2Delta_da2);
+  }
+  return _SUCCESS_;
+  /** 変更ここまで **/
+
   /** - first, define the function w(a) */
   switch (pba->fluid_equation_of_state) {
   case CLP:
@@ -1031,6 +1106,13 @@ int background_indices(
   /* index for scale factor */
   class_define_index(pba->index_bg_a,_TRUE_,index_bg,1);
 
+/* Unified A10 用の出力インデックスを順番に割り振る */
+  if (pba->has_unified_a10 == _TRUE_) {
+    class_define_index(pba->index_bg_rho_phi, _TRUE_, index_bg, 1);
+    class_define_index(pba->index_bg_w_phi, _TRUE_, index_bg, 1);
+    class_define_index(pba->index_bg_Gamma_drag, _TRUE_, index_bg, 1);
+  }
+
   /* - indices for H and its conformal-time-derivative */
   class_define_index(pba->index_bg_H,_TRUE_,index_bg,1);
   class_define_index(pba->index_bg_H_prime,_TRUE_,index_bg,1);
@@ -1047,6 +1129,10 @@ int background_indices(
